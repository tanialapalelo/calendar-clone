# Test environment (used by pnpm -C apps/api test:e2e)
NODE_ENV=test

# Server (not super important for in-memory e2e, but some modules may read these)
PORT=3001
WEB_ORIGIN=http://localhost:3000

# Database (IMPORTANT: dedicated test DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/calendar_clone_test?schema=public

# Auth cookie + JWT (TEST ONLY — do not reuse prod secret)
JWT_SECRET=test-secret
COOKIE_NAME=access_token

# Google OAuth (not used in e2e tests; leave blank)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
