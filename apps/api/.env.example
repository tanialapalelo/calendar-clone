PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/calendar?schema=public
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/google/callback
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-string
COOKIE_NAME=access_token

FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# Mail / Brevo (SMTP) example
# For Brevo SMTP Relay use the host and credentials from your Brevo account
# You can either set the generic MAIL_* vars or provider-specific BREVO_SMTP_* aliases.
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your-smtp-login
MAIL_PASS=your-smtp-password-or-api-key
MAIL_FROM="Calendar Clone" <no-reply@yourdomain.com>
MAIL_SECURE=0 # 0 = STARTTLS (587), 1 = implicit TLS (465)
