PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/calendar?schema=public
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/auth/google/callback
WEB_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-string
COOKIE_NAME=access_token

FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ── Email delivery ───────────────────────────────────────────────────────────
#
# RECOMMENDED for production (Render, Vercel, Railway, etc.):
#   Set BREVO_API_KEY — uses Brevo's HTTP API (HTTPS port 443).
#   Cloud platforms block outbound SMTP ports (25, 465, 587) at the network
#   level, so SMTP will always time-out in those environments.
#
#   Get your key: Brevo dashboard → SMTP & API → API Keys → Create a new key
#
BREVO_API_KEY=your-brevo-api-key

# Sender address shown in the From header.
# Format: "Display Name <email@yourdomain.com>" or just "email@yourdomain.com"
MAIL_FROM="Calendar Clone" <no-reply@yourdomain.com>

# ── SMTP (local dev only via MailHog) ────────────────────────────────────────
# Only used when BREVO_API_KEY is NOT set. Works with MailHog locally.
# Do NOT rely on these in production — cloud platforms block SMTP ports.
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=0
